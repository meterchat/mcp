{
  "name": "@meter/mcp-server",
  "version": "0.1.0",
  "description": "Meter MCP server — access your meter.chat decisions, blueprints, and debates from your IDE",
  "license": "MIT",
  "type": "module",
  "bin": {
    "meter-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --loader ts-node/esm src/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "meter",
    "meter-chat",
    "ai",
    "decisions",
    "blueprints",
    "debates",
    "cursor",
    "claude-code",
    "codex"
  ]
}
